{
	"name": "notional-vault-publisher",
	"version": "0.3.1",
	"description": "Deliberate one-way Obsidian to Notion publication with stable page identity and note-local assets.",
	"main": "main.js",
	"bin": {
		"notional-publish": "bin/notional-publish.mjs"
	},
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:obsidian": "eslint --config eslint.obsidian.mjs main.ts settingTab.ts \"service/**/*.ts\"",
		"test": "npx jest"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"notion",
		"notion-api",
		"obsidian-to-notion",
		"obsidian-notion-sync",
		"two-way-sync",
		"markdown",
		"note-taking",
		"knowledge-management",
		"pkm",
		"second-brain"
	],
	"author": "bryanbans",
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@types/jest": "^29.5.12",
		"@types/node": "^20.14.0",
		"esbuild": "^0.25.0",
		"eslint": "^9.0.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"jest": "^29.7.0",
		"obsidian": "^1.13.1",
		"ts-jest": "^29.2.0",
		"tslib": "^2.8.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.0.0"
	},
	"overrides": {
		"katex": "^0.16.21"
	},
	"dependencies": {
		"@tryfabric/martian": "^1.2.4",
		"yaml": "^2.5.0"
	}
}
